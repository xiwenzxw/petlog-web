rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isFamilyOwner(familyId) {
      return signedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.ownerId == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /families/{familyId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isFamilyMember(familyId);
      allow update, delete: if isFamilyOwner(familyId);

      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow create: if signedIn() && memberId == request.auth.uid
          && (
            isFamilyOwner(familyId)
            || (
              request.resource.data.inviteCode is string
              && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.familyId == familyId
              && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.active == true
            )
          );
        allow update: if isFamilyOwner(familyId) || (signedIn() && memberId == request.auth.uid);
        allow delete: if isFamilyOwner(familyId) || (signedIn() && memberId == request.auth.uid);
      }

      match /app/{document=**} {
        allow read, write: if isFamilyMember(familyId);
      }
    }

    match /invites/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isFamilyOwner(request.resource.data.familyId);
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
